                <div class="form-group">
                    <label data-i18n="contact.name.label">Tu Nombre</label>
                    <input type="text" name="name" required placeholder="ej. Juan Pérez" data-i18n-placeholder="contact.name.placeholder" />
                </div>
                <div class="form-group">
                    <label data-i18n="contact.email.label">Tu Correo Electrónico</label>
                    <input type="email" name="email" required placeholder="ej. juan@ejemplo.com" data-i18n-placeholder="contact.email.placeholder" />
                </div>
                <div class="form-group">
                    <label data-i18n="contact.message.label">Tu Mensaje</label>
                    <textarea name="message" required placeholder="Cuéntame sobre tu proyecto o consulta..." rows="4" data-i18n-placeholder="contact.message.placeholder"></textarea>
