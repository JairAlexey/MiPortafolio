    <script>
        import * as THREE from 'three';

        const container = document.getElementById('canvas-container');

        // Escena
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(document.documentElement.getAttribute('data-theme') === 'dark' ? 0x0f1115 : 0xffffff);
        scene.fog = new THREE.Fog(scene.background, 10, 25);

        window.addEventListener('theme-changed', (e) => {
            const color = e.detail === 'dark' ? 0x0f1115 : 0xffffff;
            scene.background.setHex(color);
            scene.fog.color.setHex(color);
        });

        // Cámara
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.z = 15;

        // Renderizador
        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        container.appendChild(renderer.domElement);

        let mouseX = 0;
        let mouseY = 0;
        let targetX = 0;
        let targetY = 0;
        const windowHalfX = window.innerWidth / 2;
        const windowHalfY = window.innerHeight / 2;

        document.addEventListener('mousemove', (event) => {
            mouseX = (event.clientX - windowHalfX);
            mouseY = (event.clientY - windowHalfY);
        });

        document.addEventListener('touchmove', (event) => {
            if (event.touches.length > 0) {
                mouseX = (event.touches[0].clientX - windowHalfX);
                mouseY = (event.touches[0].clientY - windowHalfY);
            }
        }, { passive: true });

        // --- SISTEMA DE PARTÍCULAS ---
        const particleCount = 4500;
        const geometry = new THREE.BufferGeometry();
        const positions = new Float32Array(particleCount * 3);
        const colors = new Float32Array(particleCount * 3);
        const sizes = new Float32Array(particleCount);
        const phases = new Float32Array(particleCount); // Para controlar el fade in/out
        const baseSizes = new Float32Array(particleCount); // Guardamos el tamaño original

        const radius = 6;
        const colorPalette = [
            new THREE.Color('#FF5722'),
            new THREE.Color('#FFC107'),
            new THREE.Color('#2196F3'),
            new THREE.Color('#9C27B0'),
            new THREE.Color('#E91E63'),
            new THREE.Color('#00BCD4')
        ];

        for (let i = 0; i < particleCount; i++) {
            const phi = Math.acos(-1 + (2 * i) / particleCount);
            const theta = Math.sqrt(particleCount * Math.PI) * phi;
            const r = radius + (Math.random() * 0.8 - 0.4);

            positions[i * 3] = r * Math.cos(theta) * Math.sin(phi);
            positions[i * 3 + 1] = r * Math.sin(theta) * Math.sin(phi);
            positions[i * 3 + 2] = r * Math.cos(phi);

            const color = colorPalette[Math.floor(Math.random() * colorPalette.length)];
            colors[i * 3] = color.r;
            colors[i * 3 + 1] = color.g;
            colors[i * 3 + 2] = color.b;

            const size = Math.random() < 0.1 ? Math.random() * 0.3 + 0.15 : Math.random() * 0.1 + 0.05;
            baseSizes[i] = size;
            sizes[i] = size;
            
            // Fase aleatoria para que parpadeen de forma desincronizada
            phases[i] = Math.random() * Math.PI * 2; 
        }

        geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
        geometry.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
        geometry.setAttribute('phase', new THREE.BufferAttribute(phases, 1));

        const uniforms = {
            time: { value: 0 }
        };

        const material = new THREE.ShaderMaterial({
            uniforms: uniforms,
            vertexShader: `
                attribute float size;
                attribute float phase;
                varying vec3 vColor;
                varying float vAlpha;
                uniform float time;
                void main() {
                    vColor = color;
                    
                    // Onda que viaja de abajo hacia arriba
                    float wave = sin(position.y * 1.5 - time * 2.0) * 0.5 + 0.5;
                    
                    // Parpadeo individual
                    float blink = sin(time * 1.5 + phase) * 0.5 + 0.5;
                    
                    // Combinación de la onda y el parpadeo
                    float combined = wave * 0.6 + blink * 0.4;
                    // Aseguramos un mínimo de visibilidad (0.25 a 1.0) para mantener la forma del orbe
                    float activeFactor = combined * 0.75 + 0.25;
                    vAlpha = activeFactor;
                    
                    vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
                    // Factor de escala incrementado para hacerlas más notorias
                    gl_PointSize = size * activeFactor * 220.0 * (1.0 / -mvPosition.z);
                    gl_Position = projectionMatrix * mvPosition;
                }
            `,
            fragmentShader: `
                varying vec3 vColor;
                varying float vAlpha;
                void main() {
                    vec2 coord = gl_PointCoord - vec2(0.5);
                    float dist = length(coord);
                    if(dist > 0.5) discard;
                    
                    // Bordes suaves y más brillo general
                    float alpha = smoothstep(0.5, 0.3, dist) * vAlpha;
                    gl_FragColor = vec4(vColor, alpha * 1.0);
                }
            `,
            transparent: true,
            vertexColors: true,
            depthWrite: false
        });

        const particles = new THREE.Points(geometry, material);
        scene.add(particles);

        const outerGeometry = geometry.clone();
        const outerMaterial = material.clone();
        outerMaterial.uniforms = uniforms; // Compartir el mismo tiempo
        const outerParticles = new THREE.Points(outerGeometry, outerMaterial);
        outerParticles.scale.set(1.2, 1.2, 1.2);
        scene.add(outerParticles);

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);
            const elapsedTime = clock.getElapsedTime();

            targetX = mouseX * 0.001;
            targetY = mouseY * 0.001;

            particles.rotation.y += 0.002;
            particles.rotation.x += 0.001;
            outerParticles.rotation.y -= 0.001;
            outerParticles.rotation.x -= 0.002;

            particles.rotation.y += 0.05 * (targetX - particles.rotation.y);
            particles.rotation.x += 0.05 * (targetY - particles.rotation.x);

            scene.position.x += (mouseX * 0.005 - scene.position.x) * 0.05;
            scene.position.y += (-mouseY * 0.005 - scene.position.y) * 0.05;

            // Actualizar el tiempo para los shaders
            uniforms.time.value = elapsedTime;

            const scale = 1 + Math.sin(elapsedTime * 0.5) * 0.02;
            particles.scale.set(scale, scale, scale);

            renderer.render(scene, camera);
        }

        animate();
    </script>
</body>
</html>

